# macOS / OS files
.DS_Store
Thumbs.db
*.swp
*.swo

# Claude Code local session/permission state (per-machine)
.claude/

# Secrets — never commit
.env
.env.local
.env.*.local
*.key
*.pem
credentials*
secrets/

# Logs
*.log

# Python (Stage 1 — when we start building)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node (in case any tooling brings it)
node_modules/
package-lock.json
yarn.lock

# Build artifacts
dist/
build/
*.egg

# IDE
.idea/
.vscode/
*.iml

# Coverage
htmlcov/
.coverage
.tox/

# Playwright MCP runtime output (page snapshots + console logs)
.playwright-mcp/

# Local AI data — never commit memory/embeddings
data/
~/.kage/
*.faiss
*.bin
Context/

# Local-only working docs (brainstorms/scratch swept in by `git add -A`)
docs/orchestrator-brainstorm.md
docs/agents-video-brief.md
docs/mobile-arm-brainstorm.md
docs/capability-bootstrap-brainstorm.md
